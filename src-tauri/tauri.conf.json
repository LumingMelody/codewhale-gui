{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ever Pretty",
  "version": "0.1.6",
  "identifier": "com.melodylu.codewhale-gui",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ever Pretty",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "externalBin": [
      "binaries/codewhale",
      "binaries/codewhale-tui"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE1OEQzMTMxNzI2QTM2OTgKUldTWU5tcHlNVEdOcGJoSk11SW9RL3NoV0RKSmg1VUtYZllSeDF0SC8wZ0t2SFBJbXdUUXU2NTEK",
      "endpoints": [
        "https://github.com/LumingMelody/codewhale-gui/releases/latest/download/latest.json"
      ]
    }
  }
}
